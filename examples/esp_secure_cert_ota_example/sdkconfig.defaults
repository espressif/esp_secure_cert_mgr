# Enable OTA functionality
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
CONFIG_APP_PROJECT_VER_FROM_CONFIG=y
CONFIG_APP_PROJECT_VER="1.0.0"

# Enable NVS
CONFIG_NVS_ENCRYPTION=n

# Enable secure cert manager
CONFIG_ESP_SECURE_CERT_SUPPORT_LEGACY_FORMATS=n

# Enable OTA data partition
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Default OTA mode - Use Unallocated Space
CONFIG_EXAMPLE_ESP_SECURE_CERT_OTA_USE_UNALLOCATED_SPACE=y

# OTA timeout
CONFIG_EXAMPLE_OTA_RECV_TIMEOUT=5000
CONFIG_ESP_HTTPS_OTA_ALLOW_HTTP=y
# WiFi Configuration (used when CONFIG_EXAMPLE_USE_SIMULATED_OTA=n)
# CONFIG_EXAMPLE_WIFI_SSID="ESP_India"
# CONFIG_EXAMPLE_WIFI_PASSWORD="Esp@3101"
# CONFIG_EXAMPLE_CERT_OTA_URL="http://192.168.21.56:8000/esp_secure_cert.bin"
