menu "ESP Secure Cert OTA Example Configuration"

    choice EXAMPLE_ESP_SECURE_CERT_OTA_MODE
        prompt "ESP Secure Cert OTA Mode"
        default EXAMPLE_ESP_SECURE_CERT_OTA_USE_UNALLOCATED_SPACE
        help
            Select the OTA mode for esp_secure_cert partition updates.

        config EXAMPLE_ESP_SECURE_CERT_OTA_USE_UNALLOCATED_SPACE
            bool "Use Unallocated Space"
            help
                Find unallocated space in flash and use it as staging area.
                After successful download, copy to original partition.
                Uses NVS to track staging offset during download.

        config EXAMPLE_ESP_SECURE_CERT_USE_PASSIVE_OTA
            bool "Use Passive OTA Partition"
            help
                Use the passive OTA app partition as staging area.
                Validates that partition has no valid image before using.
                After successful download, copy to original partition.

        config EXAMPLE_ESP_SECURE_CERT_DIRECT_OTA
            bool "Direct OTA"
            help
                Perform OTA directly on the original esp_secure_cert partition.
                WARNING: This mode is risky as interruption will corrupt the partition.
                No staging area or rollback capability.

    endchoice

    config EXAMPLE_USE_SIMULATED_OTA
        bool "Use simulated OTA data (no network download)"
        default n
        help
            When enabled, uses simulated certificate data instead of downloading from network.
            Useful for testing OTA mechanisms without requiring WiFi or a server.
            When disabled, will download from the URL specified below.

    config EXAMPLE_WIFI_SSID
        string "WiFi SSID"
        default "myssid"
        depends on !EXAMPLE_USE_SIMULATED_OTA
        help
            SSID (network name) to connect to.

    config EXAMPLE_WIFI_PASSWORD
        string "WiFi Password"
        default "mypassword"
        depends on !EXAMPLE_WIFI_SSID
        help
            WiFi password (WPA or WPA2) to use.

    config EXAMPLE_CERT_OTA_URL
        string "ESP Secure Cert OTA URL"
        default "http://192.168.1.100:8000/esp_secure_cert.bin"
        depends on !EXAMPLE_USE_SIMULATED_OTA
        help
            URL of the esp_secure_cert binary file to download.
            Examples:
              http://192.168.1.100:8000/esp_secure_cert.bin
              https://your-server.com/certs/esp_secure_cert.bin

            To serve file locally:
              python3 -m http.server 8000
            Then use: http://<your-pc-ip>:8000/esp_secure_cert.bin

    config EXAMPLE_CERT_OTA_URL_USE_HTTPS
        bool "Use HTTPS for OTA URL"
        default n
        depends on !EXAMPLE_USE_SIMULATED_OTA
        help
            Enable if your OTA URL uses HTTPS.
            You may need to provide server certificate for validation.

    config EXAMPLE_OTA_RECV_TIMEOUT
        int "OTA receive timeout (ms)"
        default 5000
        help
            Maximum time for receiving OTA data (in milliseconds).

endmenu
